rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ─── Public Reads, Admin Writes Only ───
    // For this hackathon MVP, we allow public read access so attendees can view
    // live simulation data, but restrict writes to the simulation engine backend.

    match /crowd_zones/{zoneId} {
      allow read: if true;
      allow write: if false; // System simulation backend handles these writes securely (using Admin SDK or via App Check)
    }

    match /queues/{queueId} {
      allow read: if true;
      allow write: if false;
    }

    match /alerts/{alertId} {
      allow read: if true;
      allow write: if false;
    }

    match /incidents/{incidentId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /gates/{gateId} {
      allow read: if true;
      allow write: if false;
    }

    match /venue_stats/{statId} {
      allow read: if true;
      allow write: if false;
    }

    // Explicitly lock everything else down by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
